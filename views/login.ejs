<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Scalar Relay</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Geist', sans-serif;
            background-color: #000;
            color: #fff;
        }

        .geist-input {
            background: #000;
            border: 1px solid #333;
            transition: border-color 0.2s;
        }

        .geist-input:focus {
            border-color: #fff;
            outline: none;
        }

        .geist-button {
            background: #fff;
            color: #000;
            transition: opacity 0.2s;
        }

        .geist-button:hover {
            opacity: 0.9;
        }

        .geist-button:active {
            transform: scale(0.98);
        }
    </style>
</head>

<body class="min-h-screen flex flex-col justify-center items-center px-6 selection:bg-white selection:text-black">
    <div class="w-full max-w-sm space-y-12">
        <header class="space-y-4 text-center">
            <div class="flex justify-center mb-6">
                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center">
                    <div class="w-3 h-3 bg-black rounded-full"></div>
                </div>
            </div>
            <h1 class="text-3xl font-bold tracking-tighter">Scalar Relay</h1>
            <p class="text-gray-500 text-sm">Enter your password to access the bridge.</p>
        </header>

        <form action="/login" method="POST" class="space-y-6">
            <div class="space-y-2">
                <input type="password" name="password" placeholder="Password"
                    class="w-full geist-input rounded-md px-4 py-3 text-sm" required autofocus>
            </div>

            <% if (error) { %>
                <p class="text-[10px] text-red-500 font-bold uppercase tracking-widest text-center">
                    <%= error %>
                </p>
                <% } %>

                    <button type="submit" class="w-full geist-button py-3 rounded-md font-bold text-sm">
                        Unlock
                    </button>
        </form>

        <footer class="pt-12 text-center">
            <p class="text-[10px] text-gray-700 font-mono">SES_GATEWAY_V1.2.0 • BCRYPT_ENABLED</p>
        </footer>
    </div>
</body>

</html>