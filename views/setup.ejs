<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup | Scalar Relay</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-[#0f172a] text-slate-50 min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full">
        <div class="bg-[#1e293b] rounded-2xl border border-slate-700 p-8 shadow-2xl">
            <h1 class="text-3xl font-bold mb-2">Scalar Relay</h1>
            <p class="text-slate-400 mb-8 text-sm">Configure your SMTP bridge to get started.</p>

            <form action="/setup" method="POST" class="space-y-5">
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">SMTP Server
                        / User</label>
                    <input type="email" name="smtpUser" placeholder="your@gmail.com" required
                        class="w-full bg-[#0f172a] border border-slate-700 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">App
                        Password</label>
                    <input type="password" name="smtpPass" placeholder="•••• •••• •••• ••••" required
                        class="w-full bg-[#0f172a] border border-slate-700 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label
                            class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Host</label>
                        <input type="text" name="smtpHost" value="smtp.gmail.com" required
                            class="w-full bg-[#0f172a] border border-slate-700 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors">
                    </div>
                    <div>
                        <label
                            class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Port</label>
                        <input type="number" name="smtpPort" value="465" required
                            class="w-full bg-[#0f172a] border border-slate-700 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Primary
                        Email</label>
                    <input type="email" name="primaryEmail" placeholder="your@gmail.com" required
                        class="w-full bg-[#0f172a] border border-slate-700 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Dashboard
                        Password</label>
                    <input type="password" name="dashboardPassword" placeholder="Your Dashboard Password" required
                        class="w-full bg-[#0f172a] border border-slate-700 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors">
                    <p class="text-[10px] text-slate-500 mt-1 ml-1">Needed to access this dashboard.</p>
                </div>
                <button type="submit"
                    class="w-full bg-indigo-500 hover:bg-indigo-600 text-white font-bold py-3 rounded-lg transition-colors shadow-lg shadow-indigo-500/20">
                    Complete Setup
                </button>
            </form>
        </div>
    </div>
</body>

</html>