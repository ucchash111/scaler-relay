<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup | Scalar Relay</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Geist', sans-serif;
            background-color: #09090b;
            color: #f4f4f5;
        }

        .geist-border {
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .geist-input {
            background: #111113;
            border: 1px solid #27272a;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .geist-input:focus {
            border-color: #52525b;
            box-shadow: 0 0 0 1px #52525b;
            outline: none;
        }

        .geist-button {
            background: #fafafa;
            color: #09090b;
            transition: opacity 0.2s;
        }

        .geist-button:hover {
            opacity: 0.9;
        }

        .geist-button:active {
            transform: scale(0.98);
        }

        .geist-secondary {
            background: #18181b;
            border: 1px solid #27272a;
            color: #a1a1aa;
            transition: border-color 0.2s, color 0.2s;
        }

        .geist-secondary:hover {
            border-color: #3f3f46;
            color: #fafafa;
        }
    </style>
</head>

<body
    class="min-h-screen flex flex-col justify-center items-center px-6 selection:bg-zinc-700 selection:text-white pb-24">
    <div class="w-full max-w-2xl space-y-16 py-20">
        <header class="space-y-6">
            <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-zinc-400 rounded-full"></div>
                <span class="text-sm font-bold tracking-widest uppercase text-zinc-500">Scalar Relay v1.2.0</span>
            </div>
            <h1 class="text-5xl font-extrabold tracking-tight text-white italic">Initialize Bridge</h1>
            <p class="text-zinc-400 text-base max-w-xl leading-relaxed font-medium">Configure your global relay
                settings. The default gateway is optional—Scalar can operate purely through header-driven API
                instructions.</p>
        </header>

        <form action="/setup" method="POST" class="space-y-12">
            <!-- Auth -->
            <section class="space-y-8">
                <h2 class="text-xs font-black text-zinc-500 uppercase tracking-[0.3em] border-b border-zinc-800 pb-3">
                    Dashboard Security</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <div class="space-y-3">
                        <label class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Primary
                            Identity</label>
                        <input type="email" name="primaryEmail" placeholder="admin@domain.com"
                            class="w-full geist-input rounded-lg px-5 py-3.5 text-base text-zinc-200" required>
                    </div>
                    <div class="space-y-3">
                        <label class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Dashboard Key</label>
                        <input type="password" name="dashboardPassword" placeholder="Secure phrase"
                            class="w-full geist-input rounded-lg px-5 py-3.5 text-base text-zinc-200" required>
                    </div>
                </div>
            </section>

            <!-- SMTP Gateway -->
            <section class="space-y-8">
                <div class="flex items-center justify-between border-b border-zinc-800 pb-3">
                    <h2 class="text-xs font-black text-zinc-500 uppercase tracking-[0.3em]">Default Gateway (Optional)
                    </h2>
                    <span
                        class="text-[10px] text-zinc-700 font-mono font-bold tracking-widest">GATEWAY_V1_OPTIONAL</span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <div class="space-y-3">
                        <label class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Gateway Host</label>
                        <input type="text" name="smtpHost" placeholder="smtp.provider.com"
                            class="w-full geist-input rounded-lg px-5 py-3.5 text-base text-zinc-200">
                    </div>
                    <div class="space-y-3">
                        <label class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Gateway Port</label>
                        <input type="number" name="smtpPort" placeholder="465"
                            class="w-full geist-input rounded-lg px-5 py-3.5 text-base text-zinc-200">
                    </div>
                    <div class="space-y-3">
                        <label class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Gateway User</label>
                        <input type="text" name="smtpUser" placeholder="api-relay"
                            class="w-full geist-input rounded-lg px-5 py-3.5 text-base text-zinc-200">
                    </div>
                    <div class="space-y-3">
                        <label class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Gateway
                            Password</label>
                        <input type="password" name="smtpPass" placeholder="••••••••"
                            class="w-full geist-input rounded-lg px-5 py-3.5 text-base text-zinc-200">
                    </div>
                </div>
                <p class="text-xs text-zinc-500 leading-relaxed italic font-medium">Leave SMTP fields empty to enable
                    "Gateway Only" mode, where credentials must be passed via API headers.</p>
            </section>

            <footer class="pt-10 flex items-center justify-between border-t border-zinc-800">
                <p class="text-[10px] text-zinc-600 font-mono uppercase tracking-[0.2em] font-bold">Secured with Bcrypt
                    R12</p>
                <button type="submit"
                    class="geist-button px-12 py-4 rounded-lg font-black text-xs uppercase tracking-[0.2em]">
                    Deploy Bridge
                </button>
            </footer>
        </form>
    </div>
</body>

</html>