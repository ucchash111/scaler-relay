<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup | Scalar Relay</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Geist', sans-serif;
            background-color: #000;
            color: #fff;
        }

        .geist-border {
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .geist-input {
            background: #000;
            border: 1px solid #333;
            transition: border-color 0.2s;
        }

        .geist-input:focus {
            border-color: #fff;
            outline: none;
        }

        .geist-button {
            background: #fff;
            color: #000;
            transition: opacity 0.2s;
        }

        .geist-button:hover {
            opacity: 0.9;
        }

        .geist-button:active {
            transform: scale(0.98);
        }

        .geist-secondary {
            background: #111;
            border: 1px solid #333;
            color: #888;
            transition: border-color 0.2s, color 0.2s;
        }

        .geist-secondary:hover {
            border-color: #666;
            color: #fff;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col justify-center items-center px-6 selection:bg-white selection:text-black">
    <div class="w-full max-w-xl space-y-12">
        <header class="space-y-4">
            <div class="flex items-center gap-2">
                <div class="w-2 h-2 bg-white rounded-full"></div>
                <span class="text-xs font-medium tracking-widest uppercase text-gray-500">Scalar Relay v1.2.0</span>
            </div>
            <h1 class="text-4xl font-bold tracking-tighter">Initialize Bridge</h1>
            <p class="text-gray-400 text-sm max-w-md">Configure your global relay settings. Default SMTP settings are
                optional if you plan to provide credentials via API headers.</p>
        </header>

        <form action="/setup" method="POST" class="space-y-10">
            <!-- Auth -->
            <section class="space-y-6">
                <h2 class="text-sm font-bold text-gray-500 uppercase tracking-widest border-b border-white/10 pb-2">
                    Dashboard Security</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-xs font-medium text-gray-400">Primary Identity (Email)</label>
                        <input type="email" name="primaryEmail" placeholder="me@example.com"
                            class="w-full geist-input rounded-md px-4 py-2.5 text-sm" required>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-medium text-gray-400">Dashboard Password</label>
                        <input type="password" name="dashboardPassword" placeholder="Minimum 8 characters"
                            class="w-full geist-input rounded-md px-4 py-2.5 text-sm" required>
                    </div>
                </div>
            </section>

            <!-- SMTP Gateway -->
            <section class="space-y-6">
                <div class="flex items-center justify-between border-b border-white/10 pb-2">
                    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-widest">Default Gateway (Optional)
                    </h2>
                    <span class="text-[10px] text-gray-600 font-mono">OPT_SMTP_V1</span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-xs font-medium text-gray-400">Gateway Host</label>
                        <input type="text" name="smtpHost" placeholder="smtp.gmail.com"
                            class="w-full geist-input rounded-md px-4 py-2.5 text-sm">
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-medium text-gray-400">Gateway Port</label>
                        <input type="number" name="smtpPort" placeholder="465"
                            class="w-full geist-input rounded-md px-4 py-2.5 text-sm">
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-medium text-gray-400">Gateway User</label>
                        <input type="text" name="smtpUser" placeholder="relay@domain.com"
                            class="w-full geist-input rounded-md px-4 py-2.5 text-sm">
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-medium text-gray-400">Gateway Secret</label>
                        <input type="password" name="smtpPass" placeholder="App Password"
                            class="w-full geist-input rounded-md px-4 py-2.5 text-sm">
                    </div>
                </div>
                <p class="text-[10px] text-gray-500 italic">Leave blank to use Scalar purely as a header-driven API
                    gateway.</p>
            </section>

            <footer class="pt-6 flex items-center justify-between border-t border-white/10">
                <p class="text-[10px] text-gray-600 font-mono">SEC_HASH_BCRYPT_R12</p>
                <button type="submit" class="geist-button px-8 py-2.5 rounded-md font-bold text-sm">
                    Deploy Bridge
                </button>
            </footer>
        </form>
    </div>
</body>

</html>