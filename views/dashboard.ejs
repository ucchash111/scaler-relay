<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Scalar Relay</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Geist', sans-serif;
            background-color: #000;
            color: #fff;
        }

        .geist-border {
            border: 1px solid #1a1a1a;
        }

        .geist-card {
            background: #000;
            border: 1px solid #1a1a1a;
        }

        .geist-hover:hover {
            border-color: #333;
        }

        .geist-input {
            background: #000;
            border: 1px solid #333;
            transition: border-color 0.2s;
        }

        .geist-input:focus {
            border-color: #fff;
            outline: none;
        }

        .geist-button {
            background: #fff;
            color: #000;
            transition: opacity 0.2s;
        }

        .geist-button:hover {
            opacity: 0.9;
        }

        .geist-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: #000;
        }

        ::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 10px;
        }
    </style>
</head>

<body class="min-h-screen selection:bg-white selection:text-black">
    <!-- Nav -->
    <nav
        class="sticky top-0 z-50 bg-black/80 backdrop-blur-md border-b border-white/10 px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-4">
            <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center">
                <div class="w-2 h-2 bg-black rounded-full"></div>
            </div>
            <div class="flex flex-col">
                <h1 class="text-sm font-bold tracking-tighter">Scalar Relay</h1>
                <span class="text-[9px] font-mono text-gray-500 uppercase tracking-widest">v1.2.0 • Active</span>
            </div>
        </div>
        <div class="flex items-center gap-6">
            <div class="hidden md:flex items-center gap-2 text-[10px] font-mono text-gray-400">
                <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                Relay Online
            </div>
            <a href="/logout" class="text-xs font-medium text-gray-500 hover:text-white transition-colors">Sign Out</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-12 space-y-12">
        <!-- Stats Row -->
        <header class="grid grid-cols-1 md:grid-cols-3 gap-1 border-white/10 border-y">
            <div class="py-8 px-4 flex flex-col gap-1 border-r border-white/10">
                <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Primary Email</span>
                <span class="text-sm font-medium">
                    <%= primaryEmail %>
                </span>
            </div>
            <div class="py-8 px-4 flex flex-col gap-1 border-r border-white/10">
                <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Master API Key</span>
                <div class="flex items-center gap-2">
                    <code class="text-[10px] text-gray-400 truncate w-40" id="apikey"><%= apiKey %></code>
                    <button onclick="copyKey()"
                        class="text-[10px] text-white underline hover:no-underline">Copy</button>
                    <span id="copy-msg" class="text-[9px] text-green-500 opacity-0 transition-opacity">Copied</span>
                </div>
            </div>
            <div class="py-8 px-4 flex flex-col gap-1">
                <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Transmission Count</span>
                <span class="text-sm font-medium">
                    <%= logs.length %> <span class="text-gray-600 text-[10px]">Requests</span>
                </span>
            </div>
        </header>

        <section class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Logs -->
            <div class="lg:col-span-8 space-y-6">
                <div class="flex items-center justify-between">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400">Activity Logs</h3>
                    <span class="text-[10px] text-gray-600">RT-FEED_V12</span>
                </div>

                <div class="geist-card rounded-lg overflow-hidden border-white/5 shadow-2xl">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-white/5 border-b border-white/10">
                                <tr>
                                    <th class="px-6 py-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                                        Identity</th>
                                    <th class="px-6 py-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                                        Subject</th>
                                    <th
                                        class="px-6 py-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest text-right">
                                        Time</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5">
                                <% if (logs.length===0) { %>
                                    <tr>
                                        <td colspan="3"
                                            class="px-6 py-20 text-center text-[10px] text-gray-600 font-mono tracking-widest">
                                            LIST_NULL // WAITING FOR TRANSMISSION
                                        </td>
                                    </tr>
                                    <% } %>
                                        <% logs.forEach(log=> { %>
                                            <tr
                                                class="hover:bg-white/[0.02] transition-colors border-l-2 border-transparent hover:border-white">
                                                <td class="px-6 py-4">
                                                    <div class="flex flex-col">
                                                        <span class="text-xs font-medium">
                                                            <%= log.to %>
                                                        </span>
                                                        <span class="text-[9px] text-gray-600">
                                                            <%= log.tenant %>
                                                        </span>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span class="text-xs text-gray-500 truncate max-w-xs block">
                                                        <%= log.subject %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4 text-right">
                                                    <span class="text-[10px] font-mono text-gray-600">
                                                        <%= log.timestamp %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Side -->
            <div class="lg:col-span-4 space-y-12">
                <!-- Test -->
                <div class="space-y-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400">Test Transmission</h3>
                    <form id="test-form" class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-[10px] font-medium text-gray-600">Target Email</label>
                            <input type="email" name="to" placeholder="Check your inbox..."
                                class="w-full geist-input rounded-md px-4 py-2 text-sm" required>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-medium text-gray-600">Payload Content</label>
                            <textarea name="text" placeholder="Ping from bridge..."
                                class="w-full geist-input rounded-md px-4 py-2 text-sm h-24" required></textarea>
                        </div>
                        <button type="submit" class="w-full geist-button py-2 rounded-md font-bold text-xs">
                            Execute Pulse
                        </button>
                    </form>
                    <p id="form-msg" class="text-[10px] font-bold text-center"></p>
                </div>

                <!-- Integration -->
                <div class="space-y-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400">Integration</h3>
                    <div class="p-4 bg-white/5 rounded-lg border border-white/10 space-y-4">
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] font-bold text-gray-600 uppercase tracking-widest">cURL
                                Request</span>
                            <span class="text-[9px] text-gray-500">POST /api/send</span>
                        </div>
                        <pre class="text-[10px] text-gray-400 font-mono leading-relaxed overflow-x-auto">curl -H "x-api-key: [KEY]" \
-d '{"to":"...","subj":"..."}'</pre>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        function copyKey() {
            const range = document.createRange();
            range.selectNode(document.getElementById("apikey"));
            window.getSelection().removeAllRanges();
            window.getSelection().addRange(range);
            document.execCommand("copy");
            window.getSelection().removeAllRanges();
            const msg = document.getElementById('copy-msg');
            msg.style.opacity = '1';
            setTimeout(() => msg.style.opacity = '0', 2000);
        }

        document.getElementById('test-form').onsubmit = async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const msg = document.getElementById('form-msg');
            const formData = new FormData(e.target);
            const data = {
                to: formData.get('to'),
                subject: 'Scalar Relay Test',
                text: formData.get('text')
            };

            btn.disabled = true;
            btn.innerText = 'TRANSMITTING...';

            try {
                const res = await fetch('/api/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-api-key': '<%= apiKey %>' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    msg.className = "text-[10px] font-bold text-center text-green-500";
                    msg.innerText = "TRANSMISSION_SUCCESS";
                    setTimeout(() => location.reload(), 1000);
                } else {
                    msg.className = "text-[10px] font-bold text-center text-red-500";
                    msg.innerText = "RELAY_VOID: " + (result.error || "FAIL");
                }
            } catch (err) {
                msg.innerText = "NETWORK_ERROR";
            } finally {
                btn.disabled = false;
                btn.innerText = 'Execute Pulse';
            }
        };
    </script>
</body>

</html>