<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Scalar Relay</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Geist', sans-serif;
            background-color: #09090b;
            color: #f4f4f5;
        }

        .geist-border {
            border: 1px solid #27272a;
        }

        .geist-card {
            background: #09090b;
            border: 1px solid #18181b;
        }

        .geist-hover:hover {
            border-color: #3f3f46;
        }

        .geist-input {
            background: #111113;
            border: 1px solid #27272a;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .geist-input:focus {
            border-color: #52525b;
            box-shadow: 0 0 0 1px #52525b;
            outline: none;
        }

        .geist-button {
            background: #fafafa;
            color: #09090b;
            transition: opacity 0.2s;
        }

        .geist-button:hover {
            opacity: 0.9;
        }

        .geist-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: #09090b;
        }

        ::-webkit-scrollbar-thumb {
            background: #27272a;
            border-radius: 10px;
        }
    </style>
</head>

<body class="min-h-screen selection:bg-zinc-700 selection:text-white">
    <!-- Nav -->
    <nav
        class="sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800 px-8 py-5 flex justify-between items-center">
        <div class="flex items-center gap-6">
            <div class="w-10 h-10 bg-zinc-100 rounded-full flex items-center justify-center shadow-lg shadow-white/5">
                <div class="w-3 h-3 bg-zinc-950 rounded-full"></div>
            </div>
            <div class="flex flex-col">
                <h1 class="text-lg font-bold tracking-tight text-white italic">Scalar Relay</h1>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-[0.2em] font-bold">v1.2.0 • Active
                    Pool</span>
            </div>
        </div>
        <div class="flex items-center gap-8">
            <a href="/docs"
                class="text-sm font-bold text-zinc-400 hover:text-white transition-colors border border-zinc-800 px-4 py-1.5 rounded-full bg-zinc-900/50 uppercase tracking-widest text-[11px]">Developer
                Docs</a>
            <div
                class="hidden md:flex items-center gap-3 text-[11px] font-bold text-zinc-500 uppercase tracking-widest">
                <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span>
                Protocol Online
            </div>
            <a href="/logout"
                class="text-sm font-bold text-zinc-500 hover:text-white transition-colors uppercase tracking-widest text-[11px]">Sign
                Out</a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-8 py-16 space-y-16">
        <!-- Stats Row -->
        <header class="grid grid-cols-1 md:grid-cols-3 gap-1 border-zinc-800 border-y">
            <div class="py-12 px-8 flex flex-col gap-3 border-r border-zinc-800 bg-zinc-900/10">
                <span class="text-[11px] font-black text-zinc-500 uppercase tracking-[0.3em] font-bold">Primary
                    Identity</span>
                <span class="text-lg font-bold text-zinc-100">
                    <%= primaryEmail %>
                </span>
            </div>
            <div class="py-12 px-8 flex flex-col gap-3 border-r border-zinc-800 bg-zinc-900/10">
                <span class="text-[11px] font-black text-zinc-500 uppercase tracking-[0.3em] font-bold">Master API
                    Key</span>
                <div class="flex items-center gap-3">
                    <code
                        class="text-sm text-zinc-400 font-mono font-bold truncate w-64 bg-zinc-950/50 px-2 py-1 rounded border border-zinc-800"
                        id="apikey"><%= apiKey %></code>
                    <button onclick="copyKey()"
                        class="text-xs text-zinc-100 font-bold underline hover:no-underline uppercase tracking-widest">Copy</button>
                    <span id="copy-msg"
                        class="text-[10px] text-emerald-500 font-black opacity-0 transition-opacity tracking-widest">SUCCESS</span>
                </div>
            </div>
            <div class="py-12 px-8 flex flex-col gap-3 bg-zinc-900/10">
                <span class="text-[11px] font-black text-zinc-500 uppercase tracking-[0.3em] font-bold">Transmission
                    Flux</span>
                <span class="text-lg font-bold text-zinc-100 italic">
                    <%= logs.length %> <span
                            class="text-zinc-600 text-xs uppercase font-black tracking-[0.2em] ml-2 not-italic">Signals
                            Bursted</span>
                </span>
            </div>
        </header>

        <section class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- Logs -->
            <div class="lg:col-span-8 space-y-8">
                <div class="flex items-center justify-between px-3">
                    <h3 class="text-xs font-black uppercase tracking-[0.4em] text-zinc-500">Live Protocol Feed</h3>
                    <span
                        class="text-[10px] text-zinc-700 font-mono uppercase tracking-[0.2em] font-bold bg-zinc-900/50 px-3 py-1 rounded-full border border-zinc-800">SEQUENCE
                        OVERWATCH</span>
                </div>

                <div class="geist-card rounded-2xl overflow-hidden shadow-2xl shadow-black/80">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-zinc-900 border-b border-zinc-800">
                                <tr>
                                    <th
                                        class="px-8 py-5 text-[11px] font-black text-zinc-500 uppercase tracking-[0.2em]">
                                        Burst Identity</th>
                                    <th
                                        class="px-8 py-5 text-[11px] font-black text-zinc-500 uppercase tracking-[0.2em]">
                                        Signal Subject</th>
                                    <th
                                        class="px-8 py-5 text-[11px] font-black text-zinc-500 uppercase tracking-[0.2em] text-right">
                                        Time Matrix</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-800/40 bg-zinc-950/20">
                                <% if (logs.length===0) { %>
                                    <tr>
                                        <td colspan="3"
                                            class="px-8 py-32 text-center text-xs text-zinc-700 font-mono tracking-[0.5em] uppercase font-bold">
                                            LIST_NULL // AWAITING PROTOCOL SIGNAL BURST
                                        </td>
                                    </tr>
                                    <% } %>
                                        <% logs.forEach(log=> { %>
                                            <tr class="hover:bg-white/[0.03] transition-all group cursor-default">
                                                <td class="px-8 py-6">
                                                    <div class="flex flex-col gap-0.5">
                                                        <span
                                                            class="text-base font-bold text-zinc-200 group-hover:text-white transition-colors">
                                                            <%= log.to %>
                                                        </span>
                                                        <span
                                                            class="text-[10px] text-zinc-600 font-black uppercase tracking-[0.1em]">
                                                            <%= log.tenant %>
                                                        </span>
                                                    </div>
                                                </td>
                                                <td class="px-8 py-6">
                                                    <span
                                                        class="text-sm text-zinc-400 font-medium truncate max-w-sm block group-hover:text-zinc-300 transition-colors">
                                                        <%= log.subject %>
                                                    </span>
                                                </td>
                                                <td class="px-8 py-6 text-right">
                                                    <span
                                                        class="text-xs font-mono text-zinc-600 group-hover:text-zinc-500 font-bold">
                                                        <%= log.timestamp %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Side -->
            <div class="lg:col-span-4 space-y-16">
                <!-- Test -->
                <div class="space-y-8">
                    <div class="px-2">
                        <h3 class="text-xs font-black uppercase tracking-[0.3em] text-zinc-500 italic">Pulse Modulation
                        </h3>
                    </div>
                    <form id="test-form"
                        class="space-y-6 bg-zinc-900/20 p-8 rounded-2xl border border-zinc-800/80 shadow-inner">
                        <div class="space-y-3">
                            <label class="text-[11px] font-black text-zinc-500 uppercase tracking-[0.2em]">Target
                                Address</label>
                            <input type="email" name="to" placeholder="user@target.com"
                                class="w-full geist-input rounded-lg px-5 py-4 text-sm text-zinc-200" required>
                        </div>
                        <div class="space-y-3">
                            <label class="text-[11px] font-black text-zinc-500 uppercase tracking-[0.2em]">Subject
                                Signature</label>
                            <input type="text" name="subject" placeholder="Scalar Protocol Test"
                                class="w-full geist-input rounded-lg px-5 py-4 text-sm text-zinc-200" required>
                        </div>
                        <div class="space-y-3">
                            <label class="text-[11px] font-black text-zinc-500 uppercase tracking-[0.2em]">Payload (Rich
                                Supported)</label>
                            <textarea name="content" placeholder="<h1>Transmission</h1><p>Relay active.</p>"
                                class="w-full geist-input rounded-lg px-5 py-4 text-sm text-zinc-200 h-48 font-mono leading-relaxed resize-none"
                                required></textarea>
                        </div>
                        <div class="flex items-center justify-between pt-2">
                            <div class="flex items-center gap-4 group cursor-pointer"
                                onclick="document.getElementById('isHtml').click()">
                                <input type="checkbox" id="isHtml" name="isHtml" checked
                                    class="accent-zinc-100 h-5 w-5 bg-zinc-900 border-zinc-700 rounded transition-all cursor-pointer">
                                <label for="isHtml"
                                    class="text-[10px] text-zinc-500 font-black uppercase tracking-[0.2em] cursor-pointer select-none group-hover:text-zinc-300 transition-colors">HTML
                                    ENCAPSULATION</label>
                            </div>
                        </div>
                        <button type="submit"
                            class="w-full geist-button py-4 rounded-lg font-black text-xs uppercase tracking-[0.2em] mt-6 shadow-xl shadow-black/40">
                            Execute Pulse
                        </button>
                    </form>
                    <p id="form-msg"
                        class="text-[11px] font-black text-center uppercase tracking-[0.2em] min-h-[1.5rem]"></p>
                </div>

                <!-- System -->
                <div class="space-y-6">
                    <h3 class="text-xs font-black uppercase tracking-[0.3em] text-zinc-500 px-2">Core Insights</h3>
                    <div class="p-8 bg-zinc-900/30 rounded-2xl border border-zinc-800 space-y-6">
                        <div class="flex items-center justify-between">
                            <span class="text-[11px] font-black text-zinc-400 uppercase tracking-[0.2em]">Protocol
                                V1.2</span>
                            <span
                                class="px-2 py-0.5 bg-emerald-500/10 text-emerald-500 text-[9px] font-black rounded-full border border-emerald-500/30 tracking-widest uppercase">Hybrid_Eng</span>
                        </div>
                        <p class="text-sm text-zinc-500 leading-relaxed font-bold italic">The bridge facilitates
                            <strong>Nodemailer attachments</strong>. Base64 & link-based payloads are natively
                            supported. Consult the <a href="/docs"
                                class="text-zinc-200 underline hover:text-white transition-colors decoration-zinc-700">Schema
                                Bible</a> for definitions.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        function copyKey() {
            const range = document.createRange();
            range.selectNode(document.getElementById("apikey"));
            window.getSelection().removeAllRanges();
            window.getSelection().addRange(range);
            document.execCommand("copy");
            window.getSelection().removeAllRanges();
            const msg = document.getElementById('copy-msg');
            msg.style.opacity = '1';
            setTimeout(() => msg.style.opacity = '0', 2000);
        }

        document.getElementById('test-form').onsubmit = async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const msg = document.getElementById('form-msg');
            const formData = new FormData(e.target);
            const isHtml = formData.get('isHtml') === 'on';
            const data = {
                to: formData.get('to'),
                subject: formData.get('subject'),
                text: isHtml ? undefined : formData.get('content'),
                html: isHtml ? formData.get('content') : undefined
            };

            btn.disabled = true;
            btn.innerText = 'TRANSMITTING SIGNAL...';
            msg.innerText = "";

            try {
                const res = await fetch('/api/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-api-key': '<%= apiKey %>' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    msg.className = "text-[11px] font-black text-center text-emerald-500 uppercase tracking-[0.2em]";
                    msg.innerText = "PROTOCOL // SUCCESS";
                    setTimeout(() => location.reload(), 1500);
                } else {
                    msg.className = "text-[11px] font-black text-center text-rose-500 uppercase tracking-[0.2em]";
                    msg.innerText = "VOID // FAIL: " + (result.error || "UNKNOWN");
                }
            } catch (err) {
                msg.innerText = "NETWORK_ERROR_SIGNAL_VOID";
            } finally {
                if (!btn.disabled === false) {
                    setTimeout(() => {
                        btn.disabled = false;
                        btn.innerText = 'Execute Pulse';
                    }, 2000);
                }
            }
        };
    </script>
</body>

</html>